{
  "name": "breeze-browser",
  "productName": "Breeze",
  "version": "2.3.8",
  "description": "Breeze is a fast, Chromium-based browser with local AI, native ad blocking, and zero tracking. Your data stays yours. Forever.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --publish never",
    "release": "electron-builder --publish always"
  },
  "author": "Jake Freudinger",
  "license": "MIT",
  "devDependencies": {
    "electron": "^36.4.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.5.2",
    "electron-updater": "^6.6.2",
    "node-llama-cpp": "^3.18.1"
  },
  "build": {
    "appId": "com.jakefreudinger.breeze",
    "productName": "Breeze",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "extendInfo": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "Web URLs",
            "CFBundleURLSchemes": [
              "http",
              "https"
            ]
          }
        ],
        "NSUserActivityTypes": [
          "NSUserActivityTypeBrowsingWeb"
        ]
      },
      "entitlements": "build/entitlements.selfsigned.plist",
      "entitlementsInherit": "build/entitlements.selfsigned.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": "Breeze Signing",
      "hardenedRuntime": false
    },
    "dmg": {
      "artifactName": "Breeze-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "signAndEditExecutable": false,
      "artifactName": "Breeze-Setup.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "Froydinger",
      "repo": "breezebrowser-live"
    },
    "asarUnpack": [
      "node_modules/node-llama-cpp/**",
      "node_modules/@node-llama-cpp/**"
    ],
    "files": [
      "main.js",
      "internal-preload.js",
      "page-preload.js",
      "preload.js",
      "overlay-preload.js",
      "ui/**/*"
    ]
  }
}