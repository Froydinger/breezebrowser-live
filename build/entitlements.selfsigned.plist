<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for Electron/Chromium JIT -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- NOTE: web-browser.public-key-credential and keychain-access-groups are
       intentionally omitted — they are Apple Developer ID-only entitlements,
       and claiming them with a self-signed cert makes Gatekeeper reject the
       app ("can't be opened"). Restore the full entitlements.mac.plist when
       signing with a real Developer ID. -->
</dict>
</plist>
